{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Venda Fácil",
  "version": "0.1.0",
  "identifier": "com.vendafacil.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Venda Fácil",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "plugins": {
      "updater": {
        "active": true,
        "endpoints": [
          "https://github.com/{{YOUR_GITHUB_USER}}/{{YOUR_REPO_NAME}}/releases/latest/download/latest.json"
        ],
        "pubkey": "{{YOUR_PUBLIC_KEY}}"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
