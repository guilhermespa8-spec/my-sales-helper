{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Venda Fácil",
  "version": "0.1.0",
  "identifier": "com.vendafacil.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Venda Fácil",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/guilhermespa8-spec/my-sales-helper/releases/latest/download/latest.json"
      ],
      "pubkey": "untrusted comment: minisign public key: 37F690D8F7B13316\nRWQWM7H32JD2Nzuf8hpcA37X7/83AzfJVhDB6ZTLG+Z+zo8oWYiBZmfa"
    }
  }
}
