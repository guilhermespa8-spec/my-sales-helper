{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:8080",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Venda Fácil",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "",
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.vendafacil.app",
      "longDescription": "",
      "shortDescription": "",
      "targets": "all"
    },
    "security": {
      "csp": null
    },
    "window": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "Venda Fácil",
        "width": 800
      }
    ]
  }
}
